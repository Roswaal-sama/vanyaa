{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/", "destination": "/user/index.html" },
    { "source": "/user", "destination": "/user/index.html" },
    { "source": "/crm", "destination": "/crm/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
